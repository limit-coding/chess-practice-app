// Links the Rapfi engine static library (built by native/wrapper/CMakeLists.txt)
// into the Runner. -force_load keeps the bridge symbols alive so Dart FFI can
// resolve them via DynamicLibrary.process() at runtime.
LIBRARY_SEARCH_PATHS[sdk=iphoneos*] = $(inherited) $(SRCROOT)/../../native/wrapper/build-ios
LIBRARY_SEARCH_PATHS[sdk=iphonesimulator*] = $(inherited) $(SRCROOT)/../../native/wrapper/build-ios-sim
OTHER_LDFLAGS[sdk=iphoneos*] = $(inherited) -force_load $(SRCROOT)/../../native/wrapper/build-ios/librapfi_core.a $(SRCROOT)/../../native/wrapper/build-ios/lz4/liblz4.a -lc++
OTHER_LDFLAGS[sdk=iphonesimulator*] = $(inherited) -force_load $(SRCROOT)/../../native/wrapper/build-ios-sim/librapfi_core.a $(SRCROOT)/../../native/wrapper/build-ios-sim/lz4/liblz4.a -lc++
